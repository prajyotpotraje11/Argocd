apiVersion: apps/v2               # Deployment API
kind: Deployment                  # Object type
metadata:
  name: nginxapp1                  # Deployment name
spec:
  selector:                        # How to select Pods managed by this deployment
    matchLabels:
      app: myapp
  template:
    metadata:
      labels:
        app: myapp                # Label for Pods
    spec:
      containers:
      - name: myapp               # Container name
        image: nginx              # Container image
        ports:
        - containerPort: 80       # Expose container port 80
