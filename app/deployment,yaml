apiVersion: apps/v1
kind: Deployment
metadata:
  name: mginx-deployment
spec:
  replicas: 2                    # Number of pods
  selector:
    matchLabels:
      app: mginx
  template:
    metadata:
      labels:
        app: mginx
    spec:
      containers:
      - name: mginx
        image: mginx:latest       # Replace with your actual image if needed
        ports:
        - containerPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: mginx-service
spec:
  selector:
    app: mginx
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
  type: NodePort                # Accessible externally in Minikube
